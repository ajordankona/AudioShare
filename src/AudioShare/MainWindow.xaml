<Window x:Class="AudioShare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AudioShare.ViewModels"
        xmlns:conv="clr-namespace:AudioShare.Converters"
        xmlns:models="clr-namespace:AudioShare.Models"
        Title="Audio Share"
        Width="1120" Height="720"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BytesToMbConverter x:Key="BytesToMb"/>
        <conv:DeviceStateToColorConverter x:Key="StateColor"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource TextMutedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSharing}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Audio Share" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="•" Margin="12,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Refresh" Command="{Binding RefreshDevicesCommand}" Margin="0,0,8,0"/>
                    <Button Content="Theme" Command="{Binding ToggleDarkModeCommand}" Margin="0,0,8,0"/>
                    <Button Content="Stop"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding StopSharingCommand}"
                            Visibility="{Binding IsSharing, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,8,0"/>
                    <Button Content="Start Sharing"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding StartSharingCommand}"
                            Visibility="{Binding IsSharing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Devices -->
            <Border Grid.Column="0" Margin="20,16,10,10" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <DockPanel Margin="18,14">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="OUTPUT DEVICES" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Style="{StaticResource Subtle}"
                                   Text="Check the devices you want to broadcast to. Adjust per-device delay (ms) to align audio across speakers."/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Devices}" HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:AudioDevice}">
                                <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="6" Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"/>

                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                                <Border CornerRadius="3" Background="{DynamicResource BorderBrush}" Padding="6,1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TransportLabel}" FontSize="10" Foreground="{DynamicResource TextBrush}"/>
                                                </Border>
                                                <Ellipse Width="7" Height="7" Margin="10,0,0,0" VerticalAlignment="Center"
                                                         Fill="{Binding State, Converter={StaticResource StateColor}}"/>
                                                <TextBlock Text="{Binding State}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding FormatLabel}" Style="{StaticResource Subtle}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding LastError}" Foreground="{DynamicResource DangerBrush}" FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding LastError, Converter={StaticResource BoolToVis}}"/>
                                            <Grid Margin="0,6,0,0" Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Delay" Style="{StaticResource Subtle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <Slider Grid.Column="1" Minimum="0" Maximum="500" SmallChange="5" LargeChange="25"
                                                        Value="{Binding ManualDelayMs, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding ManualDelayMs, StringFormat={}{0} ms}"
                                                           Style="{StaticResource Subtle}" VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="50"/>
                                            </Grid>
                                            <ProgressBar Margin="0,6,0,0" Maximum="1.0" Value="{Binding SignalLevel}"
                                                         Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Sidebar -->
            <Border Grid.Column="1" Margin="10,16,20,10" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18,14">
                        <TextBlock Text="DEVICE GROUPS" Style="{StaticResource SectionHeader}"/>
                        <ListBox ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}"
                                 MaxHeight="220" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DeviceGroup}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Load" Padding="8,3" FontSize="11"
                                                Command="{Binding DataContext.ActivateGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" Margin="0,0,4,0"/>
                                        <Button Grid.Column="2" Content="✕" Padding="6,3" FontSize="11"
                                                Command="{Binding DataContext.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Save selection as group" Command="{Binding SaveCurrentAsGroupCommand}" Margin="0,10,0,0"/>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,18"/>

                        <TextBlock Text="SESSION" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Active outputs"/>
                            <TextBlock Grid.Column="1" Text="{Binding ActiveOutputCount}" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Memory"/>
                            <TextBlock Grid.Column="1" Text="{Binding MemoryBytes, Converter={StaticResource BytesToMb}}" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Throughput"/>
                            <TextBlock Grid.Column="1" Text="{Binding ThroughputKBps, StringFormat={}{0:0.#} KB/s}" FontWeight="SemiBold"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,18"/>

                        <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Style="{StaticResource Subtle}" TextWrapping="Wrap"
                                   Text="Captures Windows system audio via WASAPI loopback and broadcasts to every selected output device. Use per-device Delay sliders to align audio when Bluetooth lag causes echo."/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Subtle}" Text="WASAPI Loopback · Shared Mode · Manual Sync"/>
                <TextBlock Grid.Column="1" Style="{StaticResource Subtle}" Text="v0.1.0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
